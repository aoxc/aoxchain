{
  "schema_version": 1,
  "manifest_kind": "aoxc-environment-manifest",
  "environment": "sovereign-template",
  "family_name": "AOXC",
  "family_code": "aoxc",
  "family_id": 2626,

  "identity": {
    "chain_name": "AOXC SOVEREIGN PRIVATE TEMPLATE",
    "network_class": "sovereign_private",
    "network_serial": "2626-150",
    "chain_id": 2626100001,
    "network_id": "aoxc-sovereign-private-2626-150"
  },

  "binary_compatibility": {
    "product_name": "AOXC Node",
    "product_code": "aoxc-node",
    "binary_series": "AOXC-BIN-SERIES-001",
    "single_binary_multi_network": true,
    "environment_identity_from_manifest": true,
    "compile_time_network_binding_forbidden": true,
    "supported_manifest_schema_versions": [1],
    "supported_genesis_schema_versions": [1]
  },

  "bundle": {
    "genesis_file": "genesis.v1.json",
    "genesis_hash_file": "genesis.v1.sha256",
    "validators_file": "validators.json",
    "bootnodes_file": "bootnodes.json",
    "profile_file": "profile.toml",
    "release_policy_file": "release-policy.toml",
    "certificate_file": "certificate.json"
  },

  "integrity": {
    "hash_algorithm": "sha256",
    "deterministic_serialization_required": true,
    "manifest_governs_bundle_identity": true
  },

  "runtime_policy": {
    "reject_chain_id_mismatch": true,
    "reject_network_id_mismatch": true,
    "reject_network_serial_mismatch": true,
    "reject_missing_certificate": true,
    "reject_missing_release_policy": true,
    "reject_missing_profile": true,
    "reject_missing_validators": true,
    "reject_missing_bootnodes": true,
    "reject_manifest_genesis_hash_mismatch": true
  },

  "governance": {
    "registry_controlled": true,
    "manual_chain_id_override_forbidden": true,
    "manual_network_id_override_forbidden": true,
    "manual_network_serial_override_forbidden": true,
    "template_reuse_requires_identity_regeneration": true
  },

  "metadata": {
    "description": "Canonical AOXC sovereign private network template manifest.",
    "status": "template"
  }
}
