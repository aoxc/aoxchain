# =============================================================================
# AOXCHAIN - Workspace .gitignore
# Simple policy:
# - Keep source, docs, configs, tests, and intentional assets visible.
# - Ignore build outputs, logs, secrets, caches, and machine-local files.
# =============================================================================

# =============================================================================
# Node.js / Frontend
# =============================================================================
**/node_modules/
**/.pnpm-store/
**/.pnpm/
**/.npm/
**/.yarn/
**/.yarn/cache/
**/.yarn/unplugged/
**/.yarn/build-state.yml
**/.yarn/install-state.gz
**/.pnp.*
**/.turbo/
**/.parcel-cache/

**/dist/
**/build/
**/.next/
**/out/
**/.svelte-kit/
**/.nuxt/
**/.astro/
**/.vercel/

**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*
**/lerna-debug.log*

# =============================================================================
# Rust / Compilation
# =============================================================================
**/target/
**/cargo-incremental/
**/*.rs.bk
**/*.rlib
**/*.rmeta
**/*.wasm

**/*.exe
**/*.dll
**/*.so
**/*.dylib
**/*.a
**/*.o
**/*.obj

**/*.profraw
**/*.profdata
**/tarpaulin-report.html
**/coverage/
**/grcov/
**/target/criterion/

# =============================================================================
# Environment / Secrets
# =============================================================================
**/.env
**/.env.*
**/.envrc
**/.direnv/

!**/.env.example
!**/.env.template
!**/.env.sample

**/*.local
**/.local
**/local/
**/secrets/
**/secret/
**/private/
**/tmp-secrets/
**/config/local_config.toml
**/config/*.local.toml
**/config/*.private.toml
**/credentials.json
**/credentials/*.json

**/*.pem
**/*.key
**/*.pfx
**/*.p12
**/*.crt
**/*.cer
**/*.der
**/*.csr
**/*.jks
**/*.keystore
**/*.asc

**/.aws/
**/.gcloud/
**/.azure/
**/.terraform/
**/*.tfstate
**/*.tfstate.*
**/terraform.tfvars
**/*.auto.tfvars

**/.kube/
**/kubeconfig*
**/*.kubeconfig

# =============================================================================
# Blockchain / Runtime
# =============================================================================
**/data/
**/db/
**/database/
**/databases/
**/ledger/
**/chain-data/
**/snapshots/
**/state/
**/runtime/
**/storage/

**/keystore/
**/keystores/
**/wallets/
**/accounts/
**/*.keystore
**/*.wallet
**/*.seed
**/*.mnemonic

!**/wallets/example.json
!**/wallets/README.md

# =============================================================================
# Contract / Deployment generated outputs
# =============================================================================
**/broadcast/
**/cache/
**/typechain/
**/deployments/**/dry-run/
**/deployments/**/localhost/
**/script-output/
**/forge-cache/
**/anvil-state.json

# IMPORTANT:
# Keep the root artifacts directory visible when intentionally used.
# Ignore noisy generated content inside it, but allow curated files.
artifacts/**/*.bin
artifacts/**/*.dbg.json
artifacts/**/*.metadata.json
artifacts/**/build-info/
artifacts/**/cache/
artifacts/**/tmp/
!artifacts/
!artifacts/.gitkeep
!artifacts/README.md
!artifacts/manifests/
!artifacts/manifests/**
!artifacts/abi/
!artifacts/abi/**

# =============================================================================
# Logs
# =============================================================================
**/*.log
**/logs/
**/log/

# =============================================================================
# Testing / QA outputs
# =============================================================================
**/.cache/
**/.nyc_output/
**/junit.xml
**/test-results/
**/playwright-report/
**/benchmark-results/
**/fuzz/
**/corpus/
**/crashes/
**/shrinks/

# =============================================================================
# Docker / Containers
# =============================================================================
**/.docker/
**/.devcontainer/
**/*.tar
**/*.tar.gz
**/*.tgz
**/docker-compose.override.yml
**/compose.override.yml

# =============================================================================
# Python
# =============================================================================
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/.venv/
**/venv/
**/env/
**/.mypy_cache/
**/.pytest_cache/
**/.ruff_cache/
**/.tox/
**/.nox/

# =============================================================================
# IDE / Editor
# =============================================================================
**/.vscode/*
!**/.vscode/settings.json
!**/.vscode/tasks.json
!**/.vscode/launch.json
!**/.vscode/extensions.json

**/.idea/
**/*.iml
**/.fleet/
**/.helix/
**/.zed/
**/.project
**/.classpath
**/.settings/
*.code-workspace

**/*.swp
**/*.swo
**/*~
**/*.tmp
**/*.temp
**/*.bak

# =============================================================================
# OS noise
# =============================================================================
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# =============================================================================
# Safe keepers
# =============================================================================
!**/.gitkeep
!**/README.md

# =============================================================================
# Repository release publication hygiene (generated bundles must not be committed)
# =============================================================================
/releases/v*/manifest.json
/releases/v*/checksums.sha256
/releases/v*/compatibility.toml
/releases/v*/sbom.spdx.json
/releases/v*/provenance.intoto.jsonl
/releases/v*/binaries/
/releases/v*/signatures/

# Keep governance documents tracked
!releases/README.md
!releases/RELEASE_TEMPLATE.json

# =============================================================================
# Python virtualenv and local Python tooling (root + nested)
# =============================================================================
/.venv/
/venv/
/.python-version
**/.coverage
**/.hypothesis/
**/pip-wheel-metadata/
