# =============================================================================
# AOXCHAIN - Hardened Workspace .gitignore
# Scope: Rust workspace, multi-crate architecture, Node.js, Docker, Web tooling,
# blockchain artifacts, secrets, local developer state, and operating system noise.
#
# Security Objective:
# Prevent accidental versioning of sensitive material, machine-local state,
# generated artifacts, caches, and non-deterministic outputs across the full
# repository tree, including nested subdirectories.
# =============================================================================

# =============================================================================
# Node.js Package Managers and Frontend Tooling
# =============================================================================

# Node package trees and package manager stores.
**/node_modules/
**/.pnpm-store/
**/.pnpm/
**/.npm/
**/.yarn/
**/.yarn/cache/
**/.yarn/unplugged/
**/.yarn/build-state.yml
**/.yarn/install-state.gz
**/.pnp.*
**/.turbo/
**/.parcel-cache/

# Frontend and meta-framework build outputs.
**/dist/
**/build/
**/.next/
**/out/
**/.svelte-kit/
**/.nuxt/
**/.astro/
**/.vercel/

# Package manager debug logs.
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*
**/lerna-debug.log*

# =============================================================================
# Rust Workspace, Compilation, and Tooling
# =============================================================================

# Cargo and rustc build outputs.
**/target/
**/cargo-incremental/
**/*.rs.bk
**/*.rlib
**/*.rmeta

# Native and platform-specific binaries.
**/*.exe
**/*.dll
**/*.so
**/*.dylib
**/*.a
**/*.o
**/*.obj

# WASM outputs and generated artifacts.
**/*.wasm

# Rust coverage, profiling, and analysis outputs.
**/*.profraw
**/*.profdata
**/tarpaulin-report.html
**/coverage/
**/grcov/
**/target/criterion/

# =============================================================================
# Environment Files, Secrets, and Sensitive Credentials
# =============================================================================

# Environment variable files.
**/.env
**/.env.*
**/.envrc
**/.direnv/

# Explicitly preserve non-sensitive examples/templates where intentionally versioned.
!**/.env.example
!**/.env.template
!**/.env.sample

# Local-only configuration and secret material.
**/*.local
**/.local
**/local/
**/secrets/
**/secret/
**/private/
**/tmp-secrets/
**/config/local_config.toml
**/config/*.local.toml
**/config/*.private.toml
**/credentials.json
**/credentials/*.json

# Private keys, certificates, signing material, and secure bundles.
**/*.pem
**/*.key
**/*.pfx
**/*.p12
**/*.crt
**/*.cer
**/*.der
**/*.csr
**/*.jks
**/*.keystore
**/*.asc

# Cloud and infrastructure credentials.
**/.aws/
**/.gcloud/
**/.azure/
**/.terraform/
**/*.tfstate
**/*.tfstate.*
**/terraform.tfvars
**/*.auto.tfvars

# Kubernetes and deployment-sensitive local files.
**/.kube/
**/kubeconfig*
**/*.kubeconfig

# =============================================================================
# Blockchain, Wallets, Chains, and Runtime Data
# =============================================================================

# Runtime node data, ledgers, chain state, and snapshots.
**/data/
**/db/
**/database/
**/databases/
**/ledger/
**/chain-data/
**/snapshots/
**/state/
**/runtime/
**/storage/

# Wallets, keystores, signer exports, and private artifacts.
**/keystore/
**/keystores/
**/wallets/
**/accounts/
**/*.keystore
**/*.wallet
**/*.seed
**/*.mnemonic

# Allow explicit non-sensitive examples only.
!**/wallets/example.json
!**/wallets/README.md

# Contract deployment outputs and broadcast artifacts that may contain operational context.
**/broadcast/
**/cache/
**/artifacts/
**/typechain/
**/deployments/**/dry-run/
**/deployments/**/localhost/
**/script-output/
**/forge-cache/
**/anvil-state.json

# Logs generated by nodes, scripts, or blockchain tooling.
**/*.log
**/logs/
**/log/

# =============================================================================
# Testing, Benchmarking, Fuzzing, and QA Outputs
# =============================================================================

**/.cache/
**/.nyc_output/
**/junit.xml
**/test-results/
**/playwright-report/
**/benchmark-results/
**/fuzz/
**/corpus/
**/crashes/
**/shrinks/

# =============================================================================
# Docker, Containers, and Local Image Archives
# =============================================================================

**/.docker/
**/.devcontainer/
**/*.tar
**/*.tar.gz
**/*.tgz

# Local Docker override files commonly used for machine-specific development.
**/docker-compose.override.yml
**/compose.override.yml

# =============================================================================
# Python Tooling and Script Environments
# =============================================================================

**/__pycache__/
**/*.py[cod]
**/*$py.class
**/.venv/
**/venv/
**/env/
**/.mypy_cache/
**/.pytest_cache/
**/.ruff_cache/
**/.tox/
**/.nox/

# =============================================================================
# IDEs, Editors, and Developer-Specific Workspace State
# =============================================================================

# VS Code: ignore machine-local state but keep shared workspace configuration.
**/.vscode/*
!**/.vscode/settings.json
!**/.vscode/tasks.json
!**/.vscode/launch.json
!**/.vscode/extensions.json

# JetBrains and other editors.
**/.idea/
**/*.iml
**/.fleet/
**/.helix/
**/.zed/
**/.project
**/.classpath
**/.settings/
*.code-workspace

# Vim, Emacs, and generic editor swap/backup artifacts.
**/*.swp
**/*.swo
**/*~
**/*.tmp
**/*.temp
**/*.bak

# =============================================================================
# Operating System Noise
# =============================================================================

.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# =============================================================================
# Optional: Repository-Specific Safe Keepers
# =============================================================================

# Preserve documentation and intentionally tracked empty directories where needed.
!**/.gitkeep
!**/README.md
